#Generating source browse information for project STM8S_Demo


#Abbreviations
cc = D$:\Program$ Files$ (x86)\IAR$ Systems\Embedded$ Workbench$ 8.3\common\bin\SourceIndexer.exe
ll = D$:\Program$ Files$ (x86)\IAR$ Systems\Embedded$ Workbench$ 8.3\common\bin\PbdLink.exe
bd = D$:\Program$ Files$ (x86)\IAR$ Systems\Embedded$ Workbench$ 8.3\common\bin\makeBrowseData.exe



#Rules
rule index
  depfile = $out.dep
  command = $cc -out=$out -f $in
rule link
  command = $ll -M $out $in
rule browsedata
  command = $bd $in -output  $out



#Build steps
build stm8s_clk.pbi : index stm8s_clk.xcl
build stm8s_flash.pbi : index stm8s_flash.xcl
build stm8s_gpio.pbi : index stm8s_gpio.xcl
build stm8s_tim1.pbi : index stm8s_tim1.xcl
build stm8s_uart1.pbi : index stm8s_uart1.xcl
build crc16.pbi : index crc16.xcl
build Decode.pbi : index Decode.xcl
build eeprom.pbi : index eeprom.xcl
build gpio.pbi : index gpio.xcl
build main.pbi : index main.xcl
build motor.pbi : index motor.xcl
build stm8s_interruput.pbi : index stm8s_interruput.xcl
build timer.pbi : index timer.xcl
build usart.pbi : index usart.xcl
build STM8S_Demo_part0.pbi : link stm8s_clk.pbi stm8s_flash.pbi stm8s_gpio.pbi stm8s_tim1.pbi
build STM8S_Demo_part1.pbi : link stm8s_uart1.pbi crc16.pbi Decode.pbi eeprom.pbi
build STM8S_Demo_part2.pbi : link gpio.pbi main.pbi motor.pbi stm8s_interruput.pbi
build STM8S_Demo_part3.pbi : link timer.pbi usart.pbi
build STM8S_Demo.pbd : link STM8S_Demo_part0.pbi STM8S_Demo_part1.pbi STM8S_Demo_part2.pbi STM8S_Demo_part3.pbi
build STM8S_Demo.pbw : browsedata STM8S_Demo.pbd


